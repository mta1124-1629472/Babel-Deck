#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# commit-msg — enforce conventional commit message format
#
# Installed via:  git config core.hooksPath .git-hooks
#
# Rules:
#   • Must not be empty
#   • Subject line ≤ 72 characters
#   • Must not start with "Merge " (use --no-ff or rebase instead)
#   • Must not contain "WIP" or "wip" (use draft PRs instead)
#   • If contains "PLACEHOLDER", warn that it should be resolved
# ─────────────────────────────────────────────────────────────

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'
BOLD='\033[1m'

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

WARN=0

# ── Empty message ──────────────────────────────────────────
if [[ -z "$(echo "$MSG" | tr -d '[:space:]')" ]]; then
    echo -e "${RED}${BOLD}[commit-msg] COMMIT BLOCKED: Commit message is empty${NC}"
    exit 1
fi

# ── Subject line length ────────────────────────────────────
SUBJECT=$(echo "$MSG" | head -n 1)
SUBJECT_LEN=${#SUBJECT}
if [[ $SUBJECT_LEN -gt 72 ]]; then
    echo -e "${RED}${BOLD}[commit-msg] COMMIT BLOCKED: Subject line is $SUBJECT_LEN chars (max 72)${NC}"
    echo -e "  Subject: $SUBJECT"
    exit 1
fi

# ── No "Merge " prefix ─────────────────────────────────────
if [[ "$SUBJECT" =~ ^Merge\  ]]; then
    echo -e "${YELLOW}${BOLD}[commit-msg] WARNING: Commit starts with 'Merge' — consider rebasing instead${NC}"
    WARN=1
fi

# ── No WIP ─────────────────────────────────────────────────
if echo "$SUBJECT" | grep -qi "wip"; then
    echo -e "${RED}${BOLD}[commit-msg] COMMIT BLOCKED: Commit message contains 'WIP' — use draft PRs instead${NC}"
    exit 1
fi

# ── Placeholder warning ────────────────────────────────────
if echo "$MSG" | grep -q "PLACEHOLDER"; then
    echo -e "${YELLOW}${BOLD}[commit-msg] WARNING: Commit message contains 'PLACEHOLDER' — ensure this is intentional${NC}"
    WARN=1
fi

# ── Summary ────────────────────────────────────────────────
if [[ $WARN -gt 0 ]]; then
    echo -e "${YELLOW}[commit-msg] Commit allowed with warnings${NC}"
fi

exit 0
