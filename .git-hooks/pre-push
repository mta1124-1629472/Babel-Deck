#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# pre-push — full verification before pushing to remote
#
# Installed via:  git config core.hooksPath .git-hooks
#
# Runs the complete local verification suite:
#   1. dotnet build
#   2. dotnet test (core tests only — skips Integration/RequiresPython/RequiresFfmpeg/RequiresExternalTranslation)
#   3. Architecture linter
#   4. Python inference syntax
#
# Can be bypassed with:  git push --no-verify
# ─────────────────────────────────────────────────────────────

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'
BOLD='\033[1m'

PASS=0
FAIL=0

pass() { echo -e "  ${GREEN}✔${NC}  $1"; PASS=$((PASS+1)); }
fail() { echo -e "  ${RED}✘${NC}  $1"; FAIL=$((FAIL+1)); }
warn() { echo -e "  ${YELLOW}⚠${NC}  $1"; }

echo -e "${BOLD}[pre-push] Running full verification suite...${NC}"
echo

# ── 1. dotnet build ────────────────────────────────────────
if command -v dotnet &>/dev/null; then
    echo -e "  ${BOLD}[1/4] Building solution...${NC}"
    if dotnet build babel-player.sln --configuration Release -v q 2>&1; then
        pass "dotnet build OK (Release)"
    else
        fail "dotnet build failed"
    fi

    # ── 2. dotnet test (core only) ─────────────────────────
    echo -e "  ${BOLD}[2/4] Running core tests...${NC}"
    TEST_OUTPUT=$(dotnet test babel-player.sln \
        --configuration Release \
        --no-build \
        --filter "Category!=Integration&Category!=RequiresPython&Category!=RequiresFfmpeg&Category!=RequiresExternalTranslation" \
        --logger "console;verbosity=quiet" \
        2>&1) && TEST_RC=0 || TEST_RC=$?

    if [[ $TEST_RC -eq 0 ]]; then
        pass "Core tests passed"
    else
        echo "$TEST_OUTPUT" | tail -20
        fail "Core tests failed (exit code: $TEST_RC)"
    fi
else
    warn "dotnet not found — skipping build and test checks"
fi

# ── 3. Architecture linter ────────────────────────────────
if command -v python3 &>/dev/null; then
    echo -e "  ${BOLD}[3/4] Running architecture linter...${NC}"
    if python3 scripts/check-architecture.py 2>&1; then
        pass "Architecture checks passed"
    else
        fail "Architecture linter reported violations"
    fi
else
    warn "python3 not found — skipping architecture linter"
fi

# ── 4. Python inference syntax ─────────────────────────────
if command -v python &>/dev/null || command -v python3 &>/dev/null; then
    echo -e "  ${BOLD}[4/4] Checking Python inference syntax...${NC}"
    PY_CMD="${PY_CMD:-python3}"
    command -v python &>/dev/null && PY_CMD=python
    if $PY_CMD -m py_compile inference/main.py 2>&1; then
        pass "Python inference syntax OK"
    else
        fail "Python inference syntax errors in inference/main.py"
    fi
else
    warn "python not found — skipping Python syntax check"
fi

echo
if [[ $FAIL -gt 0 ]]; then
    echo -e "${RED}${BOLD}[pre-push] BLOCKED — $FAIL check(s) failed${NC}"
    echo -e "  To bypass (not recommended): ${BOLD}git push --no-verify${NC}"
    exit 1
else
    echo -e "${GREEN}${BOLD}[pre-push] All checks passed ($PASS passed)${NC}"
    exit 0
fi
