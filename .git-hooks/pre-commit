#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# pre-commit — lightweight guard for Babel-Player
#
# Installed via:  git config core.hooksPath .git-hooks
#
# Runs fast, local-only checks before every commit:
#   1. Architecture linter (structural rules, placeholders, provider constants)
#   2. Python syntax compile check (inference script)
#   3. Optional: dotnet build if any .cs or .csproj files changed
# ─────────────────────────────────────────────────────────────

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'
BOLD='\033[1m'

PASS=0
FAIL=0

pass() { echo -e "  ${GREEN}✔${NC}  $1"; PASS=$((PASS+1)); }
fail() { echo -e "  ${RED}✘${NC}  $1"; FAIL=$((FAIL+1)); }
warn() { echo -e "  ${YELLOW}⚠${NC}  $1"; }

echo -e "${BOLD}[pre-commit] Running lightweight architecture checks...${NC}"
echo

# ── 1. Architecture linter (Python) ────────────────────────
if command -v python3 &>/dev/null; then
    ARCH_OUT=$(python3 scripts/check-architecture.py 2>&1) && ARCH_RC=0 || ARCH_RC=$?
    if [[ $ARCH_RC -eq 0 ]]; then
        pass "Architecture checks passed"
    else
        echo "$ARCH_OUT"
        fail "Architecture linter reported violations (see above)"
    fi
else
    warn "python3 not found — skipping architecture linter"
fi

# ── 2. Python inference syntax ─────────────────────────────
if command -v python &>/dev/null || command -v python3 &>/dev/null; then
    PY_CMD="${PY_CMD:-python3}"
    if $PY_CMD -m py_compile inference/main.py 2>&1; then
        pass "Python inference syntax OK"
    else
        fail "Python inference syntax errors in inference/main.py"
    fi
else
    warn "python not found — skipping Python syntax check"
fi

# ── 3. Conditional .cs change detection → dotnet build ────
CS_FILES=$(git diff --cached --diff-filter=ACMR --name-only -- '*.cs' '*.csproj' '*.sln' 2>/dev/null || true)
if [[ -n "$CS_FILES" ]]; then
    if command -v dotnet &>/dev/null; then
        echo -e "  ${YELLOW}ℹ${NC}  C# files changed — running dotnet build..."
        if dotnet build Babel-Player.sln --no-restore -v q 2>&1; then
            pass "C# build OK"
        else
            fail "C# build failed — fix errors before committing"
        fi
    else
        warn "dotnet not found — skipping C# build check"
    fi
fi

echo
if [[ $FAIL -gt 0 ]]; then
    echo -e "${RED}${BOLD}[pre-commit] BLOCKED — $FAIL check(s) failed${NC}"
    exit 1
else
    echo -e "${GREEN}${BOLD}[pre-commit] All checks passed ($PASS passed)${NC}"
    exit 0
fi
