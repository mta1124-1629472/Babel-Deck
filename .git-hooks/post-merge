#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# post-merge — remind developer to restore after pull/merge
#
# Installed via:  git config core.hooksPath .git-hooks
#
# After a successful merge, checks if .csproj, .sln, or
# package files changed and suggests dotnet restore.
# ─────────────────────────────────────────────────────────────

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

YELLOW='\033[0;33m'
NC='\033[0m'
BOLD='\033[1m'

# Check if dependency files changed in the merge
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null | \
    grep -E '(\.csproj|\.sln|nuget\.config|packages\.config)' || true)

if [[ -n "$CHANGED" ]]; then
    echo
    echo -e "${YELLOW}${BOLD}[post-merge] Project or dependency files changed. Consider running:${NC}"
    echo -e "    ${BOLD}dotnet restore Babel-Player.sln${NC}"
    echo
fi
