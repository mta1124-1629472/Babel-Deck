<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Babel.Player.ViewModels"
        xmlns:v="using:Babel.Player.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="780"
        x:Class="Babel.Player.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Icon="/Assets/Icons/app.ico"
        Title="Babel Player - Settings"
        Width="640" Height="740"
        MinWidth="520" MinHeight="540">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="24" FontWeight="SemiBold" Text="Settings" Margin="0,0,0,20"/>

        <!-- Main content area -->
        <TabControl Grid.Row="1" Margin="0,0,0,20">

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Spacing="12">

                        <!-- Theme -->
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="Theme:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                      Width="150"/>
                        </StackPanel>

                        <!-- Default TTS Voice (hidden — wiring kept, not shown in UI) -->
                        <StackPanel Orientation="Horizontal" Spacing="20" IsVisible="False">
                            <TextBlock Text="Default TTS Voice:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding TtsVoiceOptions}"
                                      SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                                      Width="200"/>
                        </StackPanel>

                        <!-- Recent Sessions -->
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="Max Recent Sessions:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding MaxRecentSessions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60"/>
                        </StackPanel>

                        <!-- Auto-save -->
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <CheckBox IsChecked="{Binding AutoSaveEnabled}"
                                      Content="Auto-save session on exit"/>
                        </StackPanel>

                        <!-- Advanced GPU host settings -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Preferred Local GPU Backend:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding GpuBackendOptions}"
                                      SelectedItem="{Binding PreferredLocalGpuBackend, Mode=TwoWay}"
                                      Width="240"
                                      HorizontalAlignment="Left">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource GpuHostBackendDisplayConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Opacity="0.65"
                                       TextWrapping="Wrap"
                                       Text="Managed local GPU is the default low-friction path. Docker GPU host is available as an advanced backend."/>
                        </StackPanel>

                        <!-- Backend restart row -->
                        <Border Padding="10,8"
                                Background="#1A1A2A"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <TextBlock Text="Backend status:"
                                           VerticalAlignment="Center"
                                           Opacity="0.75"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding BackendStatusText}"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="Medium"/>
                                <Button Content="&#x27F3; Restart"
                                        Command="{Binding RestartBackendCommand}"
                                        IsEnabled="{Binding CanRestartBackend}"
                                        Padding="10,4"
                                        FontSize="12"
                                        ToolTip.Tip="Kill and restart the active GPU backend process (venv or Docker). Useful after changing providers or after a timeout."/>
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Advanced GPU Service URL:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding AdvancedGpuServiceUrl, Mode=TwoWay}"
                                     Width="320"
                                     HorizontalAlignment="Left"/>
                            <TextBlock Opacity="0.65"
                                       TextWrapping="Wrap"
                                       Text="Used only when the Docker GPU backend is selected. Automatic Docker startup only runs for loopback URLs such as http://localhost:8000."/>
                            <CheckBox IsChecked="{Binding AlwaysStartLocalGpuRuntimeAtAppStart}"
                                      Content="Always start local GPU runtime at app start"/>
                        </StackPanel>

                        <!-- Advanced CPU transcription tuning -->
                        <StackPanel Margin="0,6,0,0" Spacing="6">
                            <TextBlock Text="Advanced: CPU Transcription" FontWeight="SemiBold"/>
                            <TextBlock Opacity="0.65" TextWrapping="Wrap"
                                       Text="These options tune CPU-only transcription. 0 threads means auto selection by the runtime."/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="CPU Compute Type:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding TranscriptionCpuComputeTypeOptions}"
                                      SelectedItem="{Binding TranscriptionCpuComputeType, Mode=TwoWay}"
                                      Width="150"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="CPU Threads (0=auto):" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding TranscriptionCpuThreads, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="Workers:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding TranscriptionNumWorkers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem Header="Hotkeys">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Opacity="0.5" FontStyle="Italic" Margin="0,0,0,12"
                               Text="Hotkey customisation is not yet available. Shown values are the current defaults." />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="Play/Pause:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PlayPauseHotkey}" IsReadOnly="True"
                                 Width="100" Opacity="0.6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="Toggle Segment Panel:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ToggleSegmentPanelHotkey}" IsReadOnly="True"
                                 Width="100" Opacity="0.6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="Toggle Dub Mode:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ToggleDubModeHotkey}" IsReadOnly="True"
                                 Width="100" Opacity="0.6"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="Toggle Fullscreen:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ToggleFullscreenHotkey}" IsReadOnly="True"
                                 Width="100" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Video Tab -->
            <TabItem Header="Video">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Spacing="12">

                        <TextBlock Text="Hardware Decode" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding HwdecOptions}"
                                  SelectedItem="{Binding VideoHwdec, Mode=TwoWay}"
                                  Width="220" HorizontalAlignment="Left" />

                        <TextBlock Text="GPU Rendering API" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding GpuApiOptions}"
                                  SelectedItem="{Binding VideoGpuApi, Mode=TwoWay}"
                                  Width="220" HorizontalAlignment="Left" />

                        <TextBlock Text="Export Encoder (future)" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding ExportEncoderOptions}"
                                  SelectedItem="{Binding VideoExportEncoder, Mode=TwoWay}"
                                  Width="220" HorizontalAlignment="Left" />

                        <TextBlock Text="GPU-Next Backend" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <CheckBox IsChecked="{Binding VideoUseGpuNext, Mode=TwoWay}"
                                  Content="Use gpu-next video output (required for RTX enhancements)"/>
                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.6"
                                   Text="gpu-next is the newer mpv renderer. Enable this before turning on RTX Video Super Resolution or RTX HDR." />

                        <TextBlock Text="RTX Video Enhancement" FontWeight="SemiBold" Margin="0,12,0,0"/>

                        <CheckBox IsChecked="{Binding VideoVsrEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding VideoUseGpuNext}"
                                  Content="RTX Video Super Resolution (VSR)"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6"
                                    Text="AI upscaling via NVIDIA d3d11vpp. Requires RTX GPU, driver &#x2265; 551.23, and 'RTX Video Enhancement' enabled in NVIDIA Control Panel." />

                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    IsEnabled="{Binding VideoVsrEnabled}">
                            <TextBlock Text="VSR Quality:" VerticalAlignment="Center"/>
                            <Slider Minimum="1" Maximum="4"
                                    Value="{Binding VideoVsrQuality, Mode=TwoWay}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Width="140"/>
                            <TextBlock Text="{Binding VideoVsrQuality}" VerticalAlignment="Center" Width="14"/>
                            <TextBlock Opacity="0.55" VerticalAlignment="Center"
                                       Text="(1 = Performance &#xB7; 4 = Quality)"/>
                        </StackPanel>

                        <Border Background="#151522"
                                BorderBrush="#2B2940"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,8,0,0">
                            <Grid ColumnDefinitions="118,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="6">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Support" FontWeight="SemiBold" Foreground="#9A98B8" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VsrSupportHintText}" TextWrapping="Wrap" Foreground="#D8D6F2" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Requested" FontWeight="SemiBold" Foreground="#9A98B8" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VsrRequestedStateText}" TextWrapping="Wrap" Foreground="#D8D6F2" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Resolved" FontWeight="SemiBold" Foreground="#9A98B8" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VsrResolvedStateText}" TextWrapping="Wrap" Foreground="#D8D6F2" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last reason" FontWeight="SemiBold" Foreground="#9A98B8" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding VsrReasonText}" TextWrapping="Wrap" Foreground="#D8D6F2" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Last filter" FontWeight="SemiBold" Foreground="#9A98B8" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding VsrFilterText}" TextWrapping="Wrap" Foreground="#D8D6F2" />
                            </Grid>
                        </Border>

                        <CheckBox IsChecked="{Binding VideoHdrEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding VideoUseGpuNext}"
                                  Content="HDR Output Pipeline"
                                  Margin="0,8,0,0"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.6"
                                   Text="Enables mpv's HDR output path so Windows receives an HDR-capable signal. Pair with NVIDIA RTX HDR in NVIDIA Control Panel when the playback surface is one NVIDIA supports. Requires an HDR display with Windows HDR enabled." />

                        <StackPanel Spacing="8" IsEnabled="{Binding VideoHdrEnabled}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Tone Mapping:" VerticalAlignment="Center" Width="100"/>
                                <ComboBox ItemsSource="{Binding ToneMappingOptions}"
                                          SelectedItem="{Binding VideoToneMapping, Mode=TwoWay}"
                                          Width="140"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Target Peak (nits):" VerticalAlignment="Center" Width="100"/>
                                <TextBox Text="{Binding VideoTargetPeak, Mode=TwoWay}"
                                         Width="80"
                                         ToolTip.Tip="Enter a nit value (e.g. 1000) or 'auto'"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding VideoHdrComputePeak, Mode=TwoWay}"
                                      Content="Dynamic peak detection (hdr-compute-peak)"
                                      ToolTip.Tip="Per-frame brightness peak analysis. May cause brightness instability on some content."/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.6"
                                   Margin="0,12,0,0"
                                   Text="All video settings take effect after restarting the app." />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Models Tab -->
            <TabItem Header="Models">
                <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">

                    <TextBlock Grid.Row="0"
                               Text="Manage locally-hosted models. Cloud providers (OpenAI, DeepL, etc.) do not require downloads."
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ModelsTab.Models}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModelDownloadEntry">
                                    <Border Margin="0,0,0,6" Padding="10,8"
                                            Background="#1E1E2C" CornerRadius="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto">

                                            <StackPanel Grid.Column="0" Spacing="2" Width="180">
                                                <TextBlock Text="{Binding ProviderLabel}"
                                                           FontSize="9" Opacity="0.45" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ModelId}"
                                                           FontSize="12" FontWeight="Medium"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="12,0">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontSize="11"
                                                           Foreground="#A0A0B8"/>
                                                <ProgressBar Value="{Binding DownloadProgress}"
                                                             Minimum="0" Maximum="1"
                                                             Height="4"
                                                             IsVisible="{Binding IsProgressVisible}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Button Content="Download"
                                                        IsVisible="{Binding CanDownload}"
                                                        Command="{Binding DownloadCommand}"
                                                        FontSize="11" Padding="8,4"/>
                                                <Button Content="Cancel"
                                                        IsVisible="{Binding CanCancel}"
                                                        Command="{Binding CancelCommand}"
                                                        FontSize="11" Padding="8,4"/>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="About">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="Babel Player" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="{Binding AppVersion}" Opacity="0.7"/>
                    <TextBlock Grid.Row="2" Text="{Binding AppBuildDate}" Opacity="0.7"/>
                    <TextBlock Grid.Row="3" Text="AGPL-3.0 License" Opacity="0.7"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Cancel" Click="OnCancelClick"/>
            <Button Content="Apply" Click="OnApplyClick"/>
            <Button Content="OK" Click="OnOKClick"/>
        </StackPanel>
    </Grid>
</Window>
