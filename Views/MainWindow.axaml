<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Babel.Player.ViewModels"
        xmlns:v="using:Babel.Player.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Babel.Player.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/babelplayer.ico"
        Title="Babel Player"
        MinWidth="900" MinHeight="500">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top: Session info bar -->
        <Border Grid.Row="0" Padding="12,8" Background="#20808080"
                IsVisible="{Binding !Playback.IsFullscreen}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Babel Player" VerticalAlignment="Center" />
                    <Button x:Name="OpenMediaButton" Content="Open Media" Click="OnOpenMediaClick" VerticalAlignment="Center" />
                    <Button Content="Run Pipeline"
                            Command="{Binding Playback.RunPipelineCommand}"
                            IsEnabled="{Binding !Playback.IsBusy}"
                            VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" Margin="16,0" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           Text="{Binding Coordinator.CurrentSession.StatusMessage}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.6"
                           Text="{Binding Coordinator.CurrentSession.Stage, StringFormat='Stage: {0}'}" />
            </Grid>
        </Border>

        <!-- Middle: Main content area -->
        <!-- Column 0 is Auto so it collapses to zero when the segment pane Border is hidden -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

            <!-- Column 0: Segment list (collapsible) + pull tab (always visible) -->
            <!-- Inner grid keeps the pull tab present even when the pane content is hidden -->
            <Grid Grid.Column="0" ColumnDefinitions="Auto,Auto">

                <!-- Pane content — collapses to zero width when IsSegmentPaneVisible=false -->
                <Border Grid.Column="0" Width="300" BorderBrush="#40808080" BorderThickness="0,0,0,0"
                        IsVisible="{Binding Playback.IsSegmentPaneVisible}">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="12,8" Background="#10808080">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Segments" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Refresh"
                                        Command="{Binding Playback.LoadSegmentsCommand}" />
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1" x:Name="SegmentList"
                                 ItemsSource="{Binding Playback.Segments}"
                                 SelectedItem="{Binding Playback.SelectedSegment}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" BorderBrush="#20808080" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" FontWeight="SemiBold"
                                                           Text="{Binding StartSeconds, StringFormat='⏱ {0:F1}s'}" />
                                                <TextBlock Grid.Column="1" Opacity="0.5"
                                                           Text="{Binding EndSeconds, StringFormat='→ {0:F1}s'}" />
                                            </Grid>
                                            <TextBlock Text="{Binding SourceText}" TextWrapping="Wrap"
                                                       Opacity="0.7" FontSize="12" />
                                            <TextBlock Text="{Binding TranslatedText}" TextWrapping="Wrap"
                                                       FontSize="12" FontStyle="Italic" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontSize="11" Opacity="0.5">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="TTS: {0}">
                                                            <Binding Path="HasTtsAudio" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Pull tab — always visible; arrow shows which direction the pane will move -->
                <!-- ◄ when open (click collapses left), ► when closed (click expands right) -->
                <Button Grid.Column="1"
                        Content="{Binding Playback.SegmentPaneToggleLabel}"
                        Command="{Binding Playback.ToggleSegmentPaneCommand}"
                        VerticalAlignment="Center"
                        Padding="4,20"
                        BorderBrush="#40808080" BorderThickness="1,1,1,1"
                        ToolTip.Tip="Toggle segment panel" />

            </Grid>

            <!-- Column 1: Video + controls -->
            <Grid Grid.Column="1" x:Name="VideoAreaGrid" RowDefinitions="*,Auto,Auto,Auto">

                <!-- Video surface — wrapped in a Grid so the transparent input-capture
                     overlay can sit above the native HWND for PointerMoved events -->
                <Grid Grid.Row="0">
                    <Border Background="Black" Margin="4">
                        <v:MpvVideoView x:Name="VideoView" />
                    </Border>
                    <!-- Transparent overlay to capture PointerMoved events over the native
                         NativeControlHost (Win32 HWND does not bubble Avalonia input) -->
                    <Panel x:Name="VideoOverlayPanel" Background="Transparent" />
                </Grid>

                <!-- Scrub bar (auto-hides with controls) -->
                <Border Grid.Row="1" Padding="8,4"
                        IsVisible="{Binding Playback.IsControlsVisible}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Playback.SourcePositionFormatted}"
                                   VerticalAlignment="Center" FontSize="11" Opacity="0.7" Width="36" />
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding Playback.SourceDurationMs}"
                                Value="{Binding Playback.SourcePositionMs, Mode=TwoWay}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Playback.SourceDurationFormatted}"
                                   VerticalAlignment="Center" FontSize="11" Opacity="0.7" Width="36" TextAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Playback controls (auto-hides with scrub bar in fullscreen) -->
                <Border Grid.Row="2" Padding="8,4"
                        IsVisible="{Binding Playback.IsControlsVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <!-- Open Media + Run Pipeline: only shown in fullscreen (top bar hidden) -->
                        <Button Content="Open Media" Click="OnOpenMediaClick"
                                IsVisible="{Binding Playback.IsFullscreen}" />
                        <Button Content="Run Pipeline"
                                Command="{Binding Playback.RunPipelineCommand}"
                                IsEnabled="{Binding !Playback.IsBusy}"
                                IsVisible="{Binding Playback.IsFullscreen}" />
                        <Separator IsVisible="{Binding Playback.IsFullscreen}" />
                        <Button Content="&#x23EA;&#xFE0E;"
                                Command="{Binding Playback.SkipBackwardCommand}"
                                IsEnabled="{Binding Playback.HasSegments}" />
                        <Button Content="{Binding Playback.PlayPauseSourceLabel}"
                                Command="{Binding Playback.PlayPauseSourceCommand}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}" />
                        <Button Content="&#x23E9;&#xFE0E;"
                                Command="{Binding Playback.SkipForwardCommand}"
                                IsEnabled="{Binding Playback.HasSegments}" />
                        <Button Content="{Binding Playback.DubModeLabel}"
                                Command="{Binding Playback.ToggleDubModeCommand}"
                                IsEnabled="{Binding Playback.HasSegments}" />
                        <Separator />
                        <Button Content="{Binding Playback.VolumeIconLabel}"
                                Command="{Binding Playback.ToggleMuteCommand}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}" />
                        <Slider Minimum="0" Maximum="1"
                                Value="{Binding Playback.SourceVolume, Mode=TwoWay}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                Width="80" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding Playback.PlaybackRateOptions}"
                                  SelectedItem="{Binding Playback.SelectedPlaybackRate, Mode=TwoWay}"
                                  Width="70"
                                  IsEnabled="{Binding Playback.IsSourceMediaLoaded}" />
                        <Button Content="&#x26F6;"
                                Command="{Binding Playback.ToggleFullscreenCommand}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}" />
                    </StackPanel>
                </Border>

                <!-- Status bar -->
                <Border Grid.Row="3" Padding="8,4" Background="#10808080"
                        IsVisible="{Binding !Playback.IsFullscreen}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Playback.StatusText}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Opacity="0.6"
                                   Text="{Binding Playback.PlaybackState, StringFormat='State: {0}'}" />
                    </Grid>
                </Border>
            </Grid>

        </Grid>

        <!-- Bottom: Persistence info -->
        <Border Grid.Row="2" Padding="8,4" Background="#10808080"
                IsVisible="{Binding !Playback.IsFullscreen}">
            <TextBlock Text="{Binding Coordinator.PersistenceStatus}" FontSize="11" Opacity="0.5" />
        </Border>

    </Grid>

</Window>
