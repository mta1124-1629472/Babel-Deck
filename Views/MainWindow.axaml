<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Babel.Player.ViewModels"
        xmlns:v="using:Babel.Player.Views"
        xmlns:bp="using:Babel.Player"
        xmlns:models="using:Babel.Player.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="700"
        x:Class="Babel.Player.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/app.ico"
        Width="1280" Height="700"
        MinWidth="960" MinHeight="520"
        RequestedThemeVariant="Default"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- ═══════════════════════════════════════════════════
             LEFT PANEL: Pipeline
             ═══════════════════════════════════════════════════ -->
<Border Grid.Column="0" Width="260" Background="{DynamicResource PanelBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrushBrush}" BorderThickness="0,0,1,0"
        IsVisible="{Binding Playback.IsSegmentPaneVisible}">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Header -->
<Border Grid.Row="0" Padding="16,14,16,12"
        BorderBrush="{DynamicResource BorderBrushBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
<TextBlock Grid.Column="0" Text="Pipeline" FontSize="15" FontWeight="SemiBold"
                                    Foreground="{DynamicResource ControlBackgroundBrush}" VerticalAlignment="Center" />
<Button Grid.Column="1"
                                 Padding="8,4" FontSize="11"
                                 Background="{DynamicResource ButtonBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                 CornerRadius="4"
                                 Command="{Binding Playback.ClearPipelineCommand}"
                                 ToolTip.Tip="Clear pipeline and start fresh">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="🗑" FontSize="10" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Scrollable body -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,16,16,8" Spacing="20">

                        <!-- TRANSCRIPTION -->
                        <StackPanel Spacing="10">
<TextBlock Text="TRANSCRIPTION" FontSize="10"
                                        Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />

                             <StackPanel Spacing="5">
                                 <TextBlock Text="Compute" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
<ComboBox ItemsSource="{Binding Playback.InferenceRuntimeOptions}"
                                           SelectedItem="{Binding Playback.TranscriptionRuntime, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" FontSize="12"
                                           Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                           BorderBrush="{DynamicResource BorderBrushBrush}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource ComputeProfileDisplayConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                             <StackPanel Spacing="5">
                                 <TextBlock Text="Provider" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 <ComboBox ItemsSource="{Binding Playback.TranslationProviders}"
                                           SelectedItem="{Binding Playback.TranslationProvider, Mode=TwoWay}"
                                           HorizontalAlignment="Stretch" FontSize="12"
                                           Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                           BorderBrush="{DynamicResource BorderBrushBrush}" />
                            </StackPanel>

<StackPanel Spacing="5">
                                 <TextBlock Text="Model" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
<ComboBox ItemsSource="{Binding Playback.AvailableTranscriptionModels}"
                                            SelectedItem="{Binding Playback.SelectedTranscriptionModel, Mode=TwoWay}"
                                           HorizontalAlignment="Stretch" FontSize="12"
                                           Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                           BorderBrush="{DynamicResource BorderBrushBrush}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding ModelId}"/>
                                                 <TextBlock Text="⬇ Needs Download" Foreground="{DynamicResource StatusTextBrush}" IsVisible="{Binding IsDownloadVisible, FallbackValue=False}" FontSize="10" VerticalAlignment="Center"/>
                                                 <TextBlock Text="✓ Ready" Foreground="{DynamicResource StatusTextBrush}" IsVisible="{Binding IsReadyVisible, FallbackValue=False}" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Text="{Binding Playback.TranscriptionKeyStatus}"
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        IsVisible="{Binding Playback.TranscriptionKeyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- TRANSLATION -->
                        <StackPanel Spacing="10">
                            <Border BorderBrush="#252530" BorderThickness="0,1,0,0" Padding="0,10,0,0">
<TextBlock Text="TRANSLATION" FontSize="10"
                                        Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />
                            </Border>

<StackPanel Spacing="5">
                                 <TextBlock Text="Compute" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 <ComboBox ItemsSource="{Binding Playback.InferenceRuntimeOptions}"
                                           SelectedItem="{Binding Playback.TranscriptionRuntime, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" FontSize="12"
                                            Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrushBrush}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource ComputeProfileDisplayConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

<StackPanel Spacing="5">
                                 <TextBlock Text="Provider" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 <ComboBox ItemsSource="{Binding Playback.TranslationProviders}"
                                           SelectedItem="{Binding Playback.TranslationProvider, Mode=TwoWay}"
                                           HorizontalAlignment="Stretch" FontSize="12"
                                           Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                           BorderBrush="{DynamicResource BorderBrushBrush}" />
                            </StackPanel>

                             <StackPanel Spacing="5">
                                  <TextBlock Text="Voice / Model" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                  <ComboBox ItemsSource="{Binding Playback.AvailableTtsOptions}"
                                            SelectedItem="{Binding Playback.SelectedTtsOption, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" FontSize="12"
                                            Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrushBrush}">
                                     <ComboBox.ItemTemplate>
                                         <DataTemplate>
                                             <StackPanel Orientation="Horizontal" Spacing="6">
                                                 <TextBlock Text="{Binding ModelId}"/>
                                                 <TextBlock Text="⬇ Needs Download" Foreground="{DynamicResource StatusTextBrush}" IsVisible="{Binding IsDownloadVisible, FallbackValue=False}" FontSize="10" VerticalAlignment="Center"/>
                                                 <TextBlock Text="✓ Ready" Foreground="{DynamicResource StatusTextBrush}" IsVisible="{Binding IsReadyVisible, FallbackValue=False}" FontSize="10" VerticalAlignment="Center"/>
                                             </StackPanel>
                                         </DataTemplate>
                                     </ComboBox.ItemTemplate>
                                 </ComboBox>
                             </StackPanel>

                            <TextBlock Text="{Binding Playback.TtsKeyStatus}"
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        IsVisible="{Binding Playback.TtsKeyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        TextWrapping="Wrap" />
                        </StackPanel>

                         <!-- API KEYS -->
                         <StackPanel Spacing="8">
                             <Border BorderBrush="{DynamicResource BorderBrushBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                 <TextBlock Text="API KEYS" FontSize="10"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />
                             </Border>

                             <TextBlock Text="Configure credentials for the providers selected above."
                                        FontSize="11"
                                        Foreground="{DynamicResource ControlBackgroundBrush}"
                                        TextWrapping="Wrap" />

                             <Button HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Padding="10,8"
                                     FontSize="12"
                                     Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                     BorderBrush="{DynamicResource BorderBrushBrush}"
                                     CornerRadius="5"
                                     Click="OnApiKeysClick">
                                 <StackPanel Orientation="Horizontal" Spacing="5">
                                     <TextBlock Text="🔑" VerticalAlignment="Center" />
                                     <TextBlock Text="Manage API Keys" VerticalAlignment="Center" />
                                 </StackPanel>
                             </Button>
                        </StackPanel>

                         <!-- LANGUAGE ROUTING -->
                         <StackPanel Spacing="10">
                             <Border BorderBrush="{DynamicResource BorderBrushBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                 <TextBlock Text="LANGUAGE ROUTING" FontSize="10"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />
                             </Border>

                             <Grid ColumnDefinitions="*,Auto">
                                 <TextBlock Grid.Column="0" Text="Source Audio" FontSize="12"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" VerticalAlignment="Center" />
                                 <Border Grid.Column="1" Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="4"
                                         Padding="8,4">
                                     <TextBlock Text="{Binding Coordinator.CurrentSession.SourceLanguage, TargetNullValue='—'}"
                                                FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 </Border>
                             </Grid>

                             <Grid ColumnDefinitions="*,Auto">
                                 <TextBlock Grid.Column="0" Text="Target Sub/Dub" FontSize="12"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" VerticalAlignment="Center" />
                                 <Border Grid.Column="1" Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="4"
                                         Padding="8,4">
                                     <TextBlock Text="{Binding Coordinator.CurrentSession.TargetLanguage, TargetNullValue='—'}"
                                                FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 </Border>
                             </Grid>
                        </StackPanel>

                         <!-- DIARIZATION / SPEAKERS -->
                         <StackPanel Spacing="10">
                             <Border BorderBrush="{DynamicResource BorderBrushBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                 <TextBlock Text="DIARIZATION / SPEAKERS" FontSize="10"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />
                             </Border>

                             <!-- Multi-speaker toggle -->
                             <CheckBox Content="Enable multi-speaker routing"
                                       IsChecked="{Binding Playback.IsMultiSpeakerEnabled, Mode=TwoWay}"
                                       Foreground="{DynamicResource ControlBackgroundBrush}" />

                             <!-- Auto speaker detection (pyannote) — only meaningful when multi-speaker is on -->
                             <CheckBox Content="Auto speaker detection"
                                       IsChecked="{Binding Playback.IsAutoSpeakerDetectionEnabled, Mode=TwoWay}"
                                       IsEnabled="{Binding Playback.IsMultiSpeakerEnabled}"
                                       Foreground="{DynamicResource ControlBackgroundBrush}" />

                            <!-- Controls that only apply when auto-detection is enabled -->
                             <!-- HF token hint -->
                             <TextBlock Text="HuggingFace token required — set it in 🔑 API Keys above."
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        TextWrapping="Wrap"
                                        IsVisible="{Binding Playback.IsAutoSpeakerDetectionEnabled}" />

                             <!-- Speaker count constraints — only visible when auto-detection is on -->
                             <StackPanel Spacing="5"
                                         IsVisible="{Binding Playback.IsAutoSpeakerDetectionEnabled}">
                                 <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                                     <TextBlock Grid.Row="0" Grid.Column="0" Text="Min Speakers" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" VerticalAlignment="Center" />
                                     <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                    Value="{Binding Playback.DiarizationMinSpeakers, Mode=TwoWay}"
                                                    Minimum="1" Maximum="20"
                                                    Width="80"
                                                    ToolTip.Tip="Leave blank to let pyannote auto-detect" />
                                     <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Speakers" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" VerticalAlignment="Center" />
                                     <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                    Value="{Binding Playback.DiarizationMaxSpeakers, Mode=TwoWay}"
                                                    Minimum="1" Maximum="20"
                                                    Width="80"
                                                    ToolTip.Tip="Leave blank to let pyannote auto-detect" />
                                 </Grid>
                            </StackPanel>

                             <!-- Setup guide + status — only enabled when auto-detection is on -->
                             <Button Content="Get HF access (token + models)"
                                     Click="OnAutoSpeakerSetupGuideClick"
                                     IsEnabled="{Binding Playback.IsAutoSpeakerDetectionEnabled}"
                                     HorizontalAlignment="Left"
                                     ToolTip.Tip="Opens HuggingFace token settings and the two pyannote model pages you must accept" />
                             <TextBlock Text="{Binding Playback.AutoSpeakerDetectionStatus}"
                                        FontSize="11"
                                        Foreground="{DynamicResource StatusTextBrush}"
                                        IsVisible="{Binding Playback.HasAutoSpeakerDetectionStatus}"
                                        TextWrapping="Wrap" />

                             <!-- Per-speaker voice / reference clip assignment -->
                             <StackPanel Spacing="5"
                                         IsVisible="{Binding Playback.IsMultiSpeakerEnabled}">

                                 <!-- Hint shown when multi-speaker is on but no speaker IDs have been detected yet -->
                                 <TextBlock Text="Transcribe with auto-detection enabled to assign speaker IDs."
                                            FontSize="11" Foreground="{DynamicResource StatusTextBrush}" TextWrapping="Wrap"
                                            IsVisible="{Binding Playback.IsMultiSpeakerNoSpeakersYet}" />

                                 <TextBlock Text="Speaker" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                 <ComboBox ItemsSource="{Binding Playback.SpeakerIds}"
                                           SelectedItem="{Binding Playback.SelectedSpeakerId, Mode=TwoWay}"
                                           IsEnabled="{Binding Playback.HasSpeakers}"
                                           HorizontalAlignment="Stretch" FontSize="12"
                                           Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                           BorderBrush="{DynamicResource BorderBrushBrush}" />

                                 <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="4" ColumnSpacing="8">
                                     <TextBlock Grid.Row="0" Grid.Column="0" Text="Voice" FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
                                     <TextBlock Grid.Row="0" Grid.Column="1"
                                                Text="{Binding Playback.SelectedSpeakerAssignedVoice, TargetNullValue='—'}"
                                                FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" TextWrapping="Wrap" />

                                     <!-- Ref audio row — only meaningful for voice-cloning providers (XTTS, Qwen) -->
                                     <TextBlock Grid.Row="1" Grid.Column="0" Text="Ref" FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}"
                                                IsVisible="{Binding Playback.IsTtsCloningProvider}" />
                                     <TextBlock Grid.Row="1" Grid.Column="1"
                                                Text="{Binding Playback.SelectedSpeakerReferenceAudioPath, TargetNullValue='—'}"
                                                FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" TextWrapping="Wrap"
                                                IsVisible="{Binding Playback.IsTtsCloningProvider}" />
                                 </Grid>

                                 <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                     <Button Grid.Row="0" Grid.Column="0"
                                             Command="{Binding Playback.AssignSelectedSpeakerVoiceCommand}"
                                             IsEnabled="{Binding Playback.HasSpeakers}"
                                             HorizontalAlignment="Stretch"
                                             Padding="0,7" FontSize="12"
                                             Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                             CornerRadius="5"
                                             Content="Use current voice" />
                                     <Button Grid.Row="0" Grid.Column="1"
                                             Command="{Binding Playback.ClearSelectedSpeakerVoiceCommand}"
                                             IsEnabled="{Binding Playback.HasSpeakers}"
                                             HorizontalAlignment="Stretch"
                                             Padding="0,7" FontSize="12"
                                             Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                             CornerRadius="5"
                                             Content="Clear speaker voice" />
                                     <!-- Ref clip buttons — only for voice-cloning providers -->
                                     <Button Grid.Row="1" Grid.Column="0"
                                             IsEnabled="{Binding Playback.HasSpeakers}"
                                             IsVisible="{Binding Playback.IsTtsCloningProvider}"
                                             HorizontalAlignment="Stretch"
                                             Padding="0,7" FontSize="12"
                                             Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                             CornerRadius="5"
                                             Click="OnBrowseReferenceClipClick"
                                             Content="Browse ref clip" />
                                     <Button Grid.Row="1" Grid.Column="1"
                                             Command="{Binding Playback.ClearSelectedSpeakerReferenceAudioCommand}"
                                             IsEnabled="{Binding Playback.HasSpeakers}"
                                             IsVisible="{Binding Playback.IsTtsCloningProvider}"
                                             HorizontalAlignment="Stretch"
                                             Padding="0,7" FontSize="12"
                                             Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}"
                                             CornerRadius="5"
                                             Content="Clear speaker ref" />
                                </Grid>

                                 <!-- Fallback voice used when a speaker has no explicit assignment -->
                                 <StackPanel Spacing="4">
                                     <TextBlock Text="Fallback voice" FontSize="12" Foreground="{DynamicResource ControlBackgroundBrush}"
                                                ToolTip.Tip="Voice/model used for any speaker that has no explicit assignment. Leave blank to use the active TTS voice." />
                                     <TextBox Text="{Binding Playback.DefaultTtsVoiceFallback, Mode=TwoWay}"
                                              PlaceholderText="same as active TTS voice"
                                              FontSize="12" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushBrush}" />
                                 </StackPanel>

                            </StackPanel>

                        </StackPanel>

                        <!-- ACTIVE CONFIGURATION -->
                        <StackPanel Spacing="8">
                            <Border BorderBrush="#252530" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <TextBlock Text="ACTIVE CONFIG" FontSize="10"
                                            Foreground="{DynamicResource ControlBackgroundBrush}" FontWeight="SemiBold" />
                            </Border>

                            <Grid ColumnDefinitions="56,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="ASR"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
<TextBlock Grid.Row="0" Grid.Column="1"
                                        Text="{Binding Playback.ActiveTranscriptionConfigLine}"
                                        FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" TextWrapping="Wrap" />

                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
<TextBlock Grid.Row="1" Grid.Column="1"
                                        Text="{Binding Playback.ActiveCpuTuningLine}"
                                        FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" TextWrapping="Wrap" />

                                 <TextBlock Grid.Row="2" Grid.Column="0" Text="NMT"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
<TextBlock Grid.Row="2" Grid.Column="1"
                                        Text="{Binding Playback.ActiveTranslationConfigLine}"
                                        FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" TextWrapping="Wrap" />

                                 <TextBlock Grid.Row="3" Grid.Column="0" Text="TTS"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
<TextBlock Grid.Row="3" Grid.Column="1"
                                        Text="{Binding Playback.HwNpuLine}"
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        TextWrapping="Wrap" />

                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}"
                                            VerticalAlignment="Top" />
<TextBlock Grid.Row="1" Grid.Column="1"
                                        Text="{Binding Playback.HwGpuLine}"
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        TextWrapping="Wrap" />

                                 <TextBlock Grid.Row="2" Grid.Column="0" Text="RAM"
                                            FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}" />
<TextBlock Grid.Row="2" Grid.Column="1"
                                        Text="{Binding Playback.HwRamLine}"
                                        FontSize="11" Foreground="{DynamicResource StatusTextBrush}"
                                        TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Playback.PipelineStageDetail}"
                                        FontSize="11"
                                        Foreground="{DynamicResource ControlBackgroundBrush}"
                                        TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Playback.PipelineProgressStatusLine}"
                                           FontSize="10"
                                           Foreground="#8A88A8"
                                           TextWrapping="Wrap" />
                                <ProgressBar Minimum="0"
                                             Maximum="1"
                                             Value="{Binding Playback.PipelineProgressPercent}"
                                             IsIndeterminate="{Binding Playback.IsPipelineProgressIndeterminate}"
                                             Height="8"
                                             Foreground="#7C3AED"
                                             Background="#2A2A3A"
                                             HorizontalAlignment="Stretch"
                                             Margin="0,2,0,0" />
                            </Grid>
                        </StackPanel>

                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="0,10"
                                FontSize="13" FontWeight="SemiBold"
                                Foreground="White"
                                CornerRadius="6"
                                Command="{Binding Playback.RunPipelineCommand}"
                                IsEnabled="{Binding Playback.CanRunPipeline}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="▶" VerticalAlignment="Center" />
                                    <TextBlock Text="Run Pipeline" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                            <Button.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                <GradientStop Color="#4F46E5" Offset="0" />
                                                <GradientStop Color="#7C3AED" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                <GradientStop Color="#5B52F0" Offset="0" />
                                                <GradientStop Color="#8B4DF8" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style Selector="Button:pressed /template/ ContentPresenter">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                <GradientStop Color="#3D35C8" Offset="0" />
                                                <GradientStop Color="#6A2FCC" Offset="1" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Styles>
                        </Button>

                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="0,10"
                                FontSize="13" FontWeight="SemiBold"
                                Background="#6B2525" Foreground="White"
                                CornerRadius="6"
                                Command="{Binding Playback.CancelPipelineCommand}"
                                IsVisible="{Binding Playback.IsBusy}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="⏹" VerticalAlignment="Center" />
                                <TextBlock Text="Cancel Pipeline" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBlock Grid.Column="0"
                                        Text="{Binding Playback.StatusText}"
                                        FontSize="11"
                                        Foreground="{DynamicResource StatusTextBrush}"
                                        HorizontalAlignment="Center"
                                        TextWrapping="Wrap"
                                       MaxHeight="52" />

                            <Button Grid.Column="1"
                                    Command="{Binding Playback.ShowStatusErrorDetailsCommand}"
                                    IsVisible="{Binding Playback.HasErrorDetails}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Padding="6,2"
                                    MinWidth="24"
                                    FontSize="12"
                                    Background="#2A2A3A"
                                     Foreground="{DynamicResource ControlBackgroundBrush}"
                                    CornerRadius="4"
                                    ToolTip.Tip="Expand error details">
                                <TextBlock Text="↗" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             CENTER PANEL: Video player
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto"
              Background="#0E0E14">

            <!-- Diagnostics warning bar (hidden when all deps available) -->
            <Border Grid.Row="0" Background="#2A1200" Padding="10,5"
                    BorderBrush="#5A2800" BorderThickness="0,0,0,1"
                    IsVisible="{Binding Playback.HasDiagnosticsWarning}">
                <TextBlock Text="{Binding Playback.DiagnosticsWarningText}"
                                FontSize="11" Foreground="{DynamicResource StatusTextBrush}" />
            </Border>

            <!-- Video surface -->
            <Grid Grid.Row="1">
                <Border Background="Black" Margin="0">
                    <v:MpvVideoView x:Name="VideoView" />
                </Border>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="10,6"
                        Background="#151522"
                        BorderBrush="#2B2940"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsVisible="{Binding Playback.HasVsrPlaybackStatus}">
                    <TextBlock Text="{Binding Playback.VsrPlaybackStatusText}"
                               FontSize="11"
                                Foreground="{DynamicResource ControlBackgroundBrush}"
                               TextWrapping="Wrap" />
                </Border>
                <Panel x:Name="VideoOverlayPanel" Background="Transparent" />

            </Grid>

            <!-- Scrub bar -->
            <Border Grid.Row="2" Padding="12,5"
                    IsVisible="{Binding Playback.IsControlsVisible}">
                <Grid ColumnDefinitions="40,*,40">
                     <TextBlock Grid.Column="0"
                                Text="{Binding Playback.SourcePositionFormatted}"
                                FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}"
                                VerticalAlignment="Center" />
                    <Slider Grid.Column="1"
                            Minimum="0"
                            Maximum="{Binding Playback.SourceDurationMs}"
                            Value="{Binding Playback.SourcePositionMs, Mode=TwoWay}"
                            IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                            VerticalAlignment="Center" />
                     <TextBlock Grid.Column="2"
                                Text="{Binding Playback.SourceDurationFormatted}"
                                FontSize="11" Foreground="{DynamicResource ControlBackgroundBrush}"
                                VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
            </Border>

            <!-- Controls bar -->
            <Border Grid.Row="3" Padding="12,9"
                    IsVisible="{Binding Playback.IsControlsVisible}">
                <Border.Styles>
                    <Style Selector="Button.control-pill">
                        <Setter Property="Foreground" Value="#A8A8C8" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                    <Style Selector="Button.control-pill /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.control-pill:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1D1D2A" />
                    </Style>
                    <Style Selector="Button.control-pill:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="#252537" />
                    </Style>
                    <Style Selector="Button.control-pill.active">
                        <Setter Property="Foreground" Value="#E7DBFF" />
                        <Setter Property="BorderBrush" Value="#6C4AF2" />
                    </Style>
                    <Style Selector="Button.control-pill.active /template/ ContentPresenter">
                        <Setter Property="Background" Value="#312350" />
                    </Style>

                    <!-- Dev toolbar pill style: amber tint so it's visually distinct -->
                    <Style Selector="Button.dev-pill">
                        <Setter Property="Foreground" Value="#D4A017" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="#3A3010" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                    <Style Selector="Button.dev-pill /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.dev-pill:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#2A2010" />
                    </Style>
                    <Style Selector="Button.dev-pill:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="#38280A" />
                    </Style>
                </Border.Styles>

                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">

                    <!-- Left: open media + CC + dub mode toggle -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2"
                                VerticalAlignment="Center">
                        <Button Classes="control-pill"
                                Content="📁"
                                Padding="9,7"
                                FontSize="16"
                                Background="Transparent"
                                Click="OnOpenMediaClick"
                                ToolTip.Tip="Open media" />
                        <Button Content="{Binding Playback.SubtitleToggleLabel}"
                                Classes="control-pill"
                                Command="{Binding Playback.ToggleSubtitlesCommand}"
                                IsEnabled="{Binding Playback.HasSegments}"
                                Padding="6,5" FontSize="14"
                                Background="Transparent"
                                ToolTip.Tip="Toggle subtitles (CC)" />
                        <Button Content="{Binding Playback.DubModeLabel}"
                                Classes="control-pill"
                                Classes.active="{Binding Playback.IsDubModeOn}"
                                Command="{Binding Playback.ToggleDubModeCommand}"
                                IsEnabled="{Binding Playback.HasSegments}"
                                Padding="6,5" FontSize="14"
                                Background="Transparent" />
                    </StackPanel>

                    <!-- Center: playback buttons in a unified transport capsule -->
                    <Border Grid.Column="2" Background="#18182A" CornerRadius="12" Padding="4,3"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <Button Classes="control-pill" Content="&#x23EE;&#xFE0E;"
                                    Command="{Binding Playback.SkipBackwardCommand}"
                                    IsEnabled="{Binding Playback.HasSegments}"
                                    Padding="8,6" FontSize="15"
                                    ToolTip.Tip="Skip to previous segment" />
                            <Button Classes="control-pill" Content="&#x23EA;&#xFE0E;"
                                    Command="{Binding Playback.SkipBackwardCommand}"
                                    IsEnabled="{Binding Playback.HasSegments}"
                                    Padding="8,6" FontSize="15" />
                            <Button Command="{Binding Playback.PlayPauseSourceCommand}"
                                    IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                    Width="42" Height="42" Padding="0" Margin="3,0"
                                    CornerRadius="21" Background="#30304A">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#3C3C5C" />
                                    </Style>
                                    <Style Selector="Button:pressed /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#252545" />
                                    </Style>
                                </Button.Styles>
                                <TextBlock Text="{Binding Playback.PlayPauseSourceLabel}"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="control-pill" Content="&#x23E9;&#xFE0E;"
                                    Command="{Binding Playback.SkipForwardCommand}"
                                    IsEnabled="{Binding Playback.HasSegments}"
                                    Padding="8,6" FontSize="15" />
                            <Button Classes="control-pill" Content="&#x23ED;&#xFE0E;"
                                    Command="{Binding Playback.SkipForwardCommand}"
                                    IsEnabled="{Binding Playback.HasSegments}"
                                    Padding="8,6" FontSize="15"
                                    ToolTip.Tip="Skip to next segment" />
                        </StackPanel>
                    </Border>

                    <!-- Right: volume + fullscreen + settings [+ dev toolbar] -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Classes="control-pill" x:Name="MuteButton"
                                Content="{Binding Playback.VolumeIconLabel}"
                                Command="{Binding Playback.ToggleMuteCommand}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                Padding="6,5" FontSize="14"
                                ToolTip.Tip="Mute / Unmute" />
                        <Slider x:Name="VolumeSlider"
                                Width="80"
                                Orientation="Horizontal"
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding Playback.SourceVolume, Mode=TwoWay}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                VerticalAlignment="Center"
                                Margin="2,0,8,0"
                                ToolTip.Tip="Volume" />

                        <Button Classes="control-pill" Content="&#x25EB;&#xFE0E;"
                                Command="{Binding Playback.ToggleSegmentPaneCommand}"
                                Padding="8,6" FontSize="14"
                                ToolTip.Tip="Toggle side panes" />

                        <Button Classes="control-pill" Content="&#x26F6;"
                                Command="{Binding Playback.ToggleFullscreenCommand}"
                                IsEnabled="{Binding Playback.IsSourceMediaLoaded}"
                                Padding="6,5" FontSize="14" />

                        <Button Classes="control-pill" Content="&#x2699;"
                                Click="OnSettingsClick"
                                Padding="6,5" FontSize="14"
                                ToolTip.Tip="Settings" />

                        <!--
                            ╔══════════════════════════════╗
                            ║  DEV BUILD TOOLBAR           ║
                            ║  Visible only in Dev builds. ║
                            ╚══════════════════════════════╝
                            AXAML has no #if support, so we gate visibility at runtime via
                            the BuildInfo.IsDevBuild static.  The Click handlers in
                            MainWindow.axaml.cs are wrapped in #if BABEL_DEV so they
                            are compiled away in Release — the buttons just won't exist.
                        -->
                        <Border Margin="6,0,0,0"
                                BorderBrush="#3A3010"
                                BorderThickness="1,0,0,0"
                                Padding="6,0,0,0"
                                IsVisible="{x:Static bp:BuildInfo.IsDevBuild}">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button Classes="dev-pill"
                                        x:Name="DevLogButton"
                                        Content="📋 Dev Log"
                                        Padding="6,5" FontSize="12"
                                        ToolTip.Tip="Open in-app dev log viewer" />
                                <Button Classes="dev-pill"
                                        x:Name="FreshStartButton"
                                        Content="🔄 Fresh Start"
                                        Padding="6,5" FontSize="12"
                                        ToolTip.Tip="Cancel pipeline, wipe session temp files, reset UI" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════════════════
             RIGHT PANEL: Segments
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Width="280" Background="#16161E"
                BorderBrush="#252530" BorderThickness="1,0,0,0"
                IsVisible="{Binding Playback.IsSegmentPaneVisible}">
            <Grid RowDefinitions="Auto,*">

                <!-- Header -->
                <Border Grid.Row="0" Padding="14,11"
                        BorderBrush="#252530" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0" Text="Segments" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#F0F0F8"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#565672"
                                    VerticalAlignment="Center" Margin="0,0,10,0"
                                    Text="{Binding Playback.Segments.Count, StringFormat='{}{0} Items'}" />

                        <Button Grid.Column="2"
                                Click="OnExportCaptionsClick"
                                Padding="7,3"
                                FontSize="11"
                                Background="#2A2A3C"
                                Foreground="#C0C0D0"
                                CornerRadius="4"
                                ToolTip.Tip="Export captions as SRT">
                            <TextBlock Text="Export" />
                        </Button>

                        <Button Grid.Column="3"
                                Command="{Binding Playback.RefreshSegmentsCommand}"
                                Background="Transparent" Padding="6,2"
                                Foreground="#A0A0B0" ToolTip.Tip="Refresh segments data">
                            <TextBlock Text="↻" FontSize="16" />
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#2A2A3A" />
                                    <Setter Property="Foreground" Value="#F0F0F8" />
                                </Style>
                            </Button.Styles>
                        </Button>

                    </Grid>
                </Border>

                <!-- Segment list -->
                <ListBox Grid.Row="1" x:Name="SegmentList"
                         ItemsSource="{Binding Playback.Segments}"
                         SelectedItem="{Binding Playback.SelectedSegment}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#20203A" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1C1C2C" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkflowSegmentState">
                            <Border Padding="14,10" BorderBrush="#252530" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,12">

                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <!-- Time range -->
                                        <TextBlock FontSize="11" Foreground="#6A6A82">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F1}s  —  {1:F1}s">
                                                    <Binding Path="StartSeconds" />
                                                    <Binding Path="EndSeconds" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <!-- Original text -->
                                        <TextBlock Text="{Binding SourceText}"
                                                   FontSize="12" Foreground="#686878"
                                                   TextWrapping="Wrap" />
                                        <!-- Translated text -->
                                        <TextBlock Text="{Binding TranslatedText}"
                                                   FontSize="13" Foreground="#E8E8F0"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Status indicator column -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Top"
                                                Margin="0,4,0,0" Spacing="4">
                                        <!-- Green dot: TTS audio ready -->
                                        <Ellipse Width="8" Height="8"
                                                 Fill="#22C55E"
                                                 IsVisible="{Binding HasTtsAudio}"
                                                 HorizontalAlignment="Center" />
                                        <!-- Orange bar: translation present, no TTS yet -->
                                        <Rectangle Width="4" Height="16"
                                                   Fill="#F59E0B"
                                                   RadiusX="2" RadiusY="2"
                                                   IsVisible="{Binding HasTranslation}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>
        </Border>

    </Grid>

</Window>
