# LFS-tracked binaries
native/win-x64/libmpv-2.dll filter=lfs diff=lfs merge=lfs -text
BabelPlayer.Tests/bin/Debug/net10.0/libmpv-2.dll filter=lfs diff=lfs merge=lfs -text
uv.exe filter=lfs diff=lfs merge=lfs -text

# Force LF for all text files
* text=auto eol=lf

# Config files you already had (redundant now but harmless to keep explicit)
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Windows-native project files that genuinely need CRLF
*.sln text eol=crlf
*.csproj text eol=crlf

# Binary files — don't touch line endings
*.png binary
*.jpg binary
*.wav binary
*.mp3 binary
*.onnx binary
*.pt binary
*.bin binary
*.whl binary
*.dll binary
*.exe binary
*.pdb binary
