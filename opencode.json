{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest"
  ],
  "lsp": {
    "ty": {
      "command": ["uv", "run", "ty", "server"],
      "extensions": [".py", ".pyi"]
    },
    "pyright": {
      "disabled": true
    },
    "python": {
      "command": ["basedpyright"],
      "extensions": [".py", ".pyi"]
    }
},
  "mcp": {
  "avalonia_docs": {
    "type": "remote",
    "url": "https://docs-mcp.avaloniaui.net/mcp",
    "enabled": true
  }
},
"permission": {
    "read": "allow",
    "doom_loop": "allow",
    "external_directory": "allow",
    "webfetch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "bash": "allow",
    "list": "allow",
    "grep": "allow",
    "glob": "allow",
    "edit": "allow"
  },
  "autoupdate": true,
  "snapshot": true,
  "share": "auto"
}